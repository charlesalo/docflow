    "isomorphic-dompurify": "^3.18.0",
    "marked": "^18.0.5",
    "next": "16.2.10",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
